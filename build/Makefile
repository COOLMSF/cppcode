# target to generate assembly for a file
src/utils/Logger.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/claude-haha.dir/build.make CMakeFiles/claude-haha.dir/src/utils/Logger.cpp.s
.PHONY : src/utils/Logger.cpp.s

